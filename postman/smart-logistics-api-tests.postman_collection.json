        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"mobile\": \"{{adminMobile}}\",\n  \"password\": \"{{password}}\",\n  \"fullName\": \"Collection Admin\",\n  \"role\": \"ROLE_ADMIN\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Admin register succeeded', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('adminToken', json.token);",
              "pm.collectionVariables.set('adminRole', json.role);"
